# Copy to .env.local for local dev. Cloudflare Pages reads these via env vars set on the project.
# Production secrets live in Cloudflare Pages + GitHub Actions; do not paste them here.

# ---- Supabase (public - shipped to browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://rnvmswyzimbjfuynoyen.supabase.co
# Get from Supabase Studio → Project Settings → API → Project API keys (publishable / anon).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Supabase (server-only - never ship to browser) ----
# Service-role / secret key. See Supabase Studio → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Pipedrive (server-only) ----
# Get from Pipedrive → Personal preferences → API.
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMAIN=hokusanteacanada

# ---- Shopify (server-only) ----
# Admin API access token from a custom app on hokusan.myshopify.com.
SHOPIFY_STORE_DOMAIN=hokusan.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ---- Email allowlist for auth gate ----
ALLOWED_EMAIL_DOMAIN=hokusan.ca
